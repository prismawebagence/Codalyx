# Copier ce fichier en .env.local (déjà gitignoré) et remplir.
# En prod : configurer ces variables dans Vercel → Settings → Environment Variables.

# Resend — envoi des emails du formulaire de contact.
# Créer un compte sur https://resend.com et générer une clé.
RESEND_API_KEY=

# Destinataire des emails reçus via le formulaire de contact.
CONTACT_TO_EMAIL=contact@prismaweb.fr

# Expéditeur. Tant que le domaine n'est pas vérifié sur Resend, garder onboarding@resend.dev.
# Une fois prismaweb.fr ajouté et vérifié sur Resend, passer à : PrismaWeb <contact@prismaweb.fr>
CONTACT_FROM_EMAIL=PrismaWeb <onboarding@resend.dev>

# Pexels — images de démos. À régénérer si l'ancienne clé a été exposée.
# https://www.pexels.com/api/
PEXELS_API_KEY=
